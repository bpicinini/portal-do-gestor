
                <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
                    <head>
                        <meta charset="UTF-8">
                        <!--[if gte mso 9]>
                        <xml>
                            <x:ExcelWorkbook>
                                <x:ExcelWorksheets>
                                    <x:ExcelWorksheet>
                                        <x:Name>Colaboradores</x:Name>
                                        <x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions>
                                    </x:ExcelWorksheet>
                                </x:ExcelWorksheets>
                            </x:ExcelWorkbook>
                        </xml>
                        <![endif]-->
                        <style>
                            table { border-collapse: collapse; width: 100%; }
                            th, td { border: 1px solid #dddddd; text-align: left; padding: 8px; }
                            th { background-color: #f2f2f2; }
                            td[data-excel-type="number"] { mso-number-format:"0\.00"; }
                            td[data-excel-type="currency"] { mso-number-format:"\"R\$\"\ #\,##0\.00"; }
                        </style>
                    </head>
                    <body>
                        <table>
                    <thead id="table-head" class="[&amp;_tr]:border-b bg-[hsl(var(--muted))]">
                        <tr class="border-b transition-colors hover:bg-[hsl(var(--muted))]/50">
                            <th class="h-12 px-4 text-left align-middle font-medium text-[hsl(var(--muted-foreground))] whitespace-nowrap bg-[hsl(var(--muted))]" data-key="colaborador" data-type="text">
                        <div class="flex items-center justify-between group">
                            <span class="sort-handle flex-grow cursor-pointer">Colaborador</span>
                            <div class="flex items-center">
                                <span class="sort-icon opacity-20 group-hover:opacity-100">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"></path><path d="m7 9 5-5 5 5"></path></svg>
                                </span>
                                <button class="filter-btn ml-1 p-1 rounded hover:bg-[hsl(var(--accent))] data-[active=true]:text-[hsl(var(--primary))] data-[active=true]:bg-[hsl(var(--accent))]" data-key="colaborador" title="Filtrar Colaborador">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                                </button>
                            </div>
                        </div>
                    </th>
                            <th class="h-12 px-4 text-left align-middle font-medium text-[hsl(var(--muted-foreground))] whitespace-nowrap bg-[hsl(var(--muted))]" data-key="tipo" data-type="text">
                        <div class="flex items-center justify-between group">
                            <span class="sort-handle flex-grow cursor-pointer">Vínculo</span>
                            <div class="flex items-center">
                                <span class="sort-icon opacity-20 group-hover:opacity-100">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"></path><path d="m7 9 5-5 5 5"></path></svg>
                                </span>
